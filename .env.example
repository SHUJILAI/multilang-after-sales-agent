# ===== LLM 配置（任何 OpenAI 兼容接口均可）=====
# 你的 API Key（必填，不填则进入"离线规则模式"，仅用知识库原文直出）
LLM_API_KEY=sk-xxxxxxxxxxxxxxxx

# 接口地址（三选一，或填你自己的代理网关）
# DeepSeek:    https://api.deepseek.com/v1
# 通义千问:    https://dashscope.aliyuncs.com/compatible-mode/v1
# OpenAI 官方: https://api.openai.com/v1
LLM_BASE_URL=https://api.deepseek.com/v1

# 模型名（与接口对应）
# DeepSeek: deepseek-chat | 通义: qwen-plus | OpenAI: gpt-4o-mini
LLM_MODEL=deepseek-chat

# ===== 服务 =====
PORT=8787

# 设备信息（会写进系统提示词，换成客户真实设备）
DEVICE_NAME=LTX-3015 光纤激光切割机
MANUAL_NAME=《LTX-3015 使用维护手册 V3.2》
